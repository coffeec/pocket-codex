diff --git a/server/modules/providers/services/pocket-session-preferences.service.ts b/server/modules/providers/services/pocket-session-preferences.service.ts
new file mode 100644
index 0000000000000000000000000000000000000000..86f527ca6134cbacd677e6901230e2ae6c664139
--- /dev/null
+++ b/server/modules/providers/services/pocket-session-preferences.service.ts
@@ -0,0 +1,118 @@
+import { randomUUID } from 'node:crypto';
+import { mkdir, readFile, rename, writeFile } from 'node:fs/promises';
+import os from 'node:os';
+import path from 'node:path';
+
+import type { LLMProvider } from '@/shared/types.js';
+
+export const POCKET_SESSION_EFFORTS = ['low', 'medium', 'high', 'xhigh'] as const;
+export type PocketSessionEffort = typeof POCKET_SESSION_EFFORTS[number];
+
+export type PocketSessionPreferences = {
+  provider: LLMProvider;
+  sessionId: string;
+  model: string | null;
+  effort: PocketSessionEffort;
+  updatedAt: string | null;
+};
+
+type PocketSessionPreferencesFile = {
+  version: 1;
+  entries: Record<string, PocketSessionPreferences>;
+};
+
+const DEFAULT_EFFORT: PocketSessionEffort = 'high';
+
+const preferencesPath = (): string => (
+  process.env.POCKETCODEX_SESSION_PREFERENCES_PATH
+  || path.join(os.homedir(), '.cloudcli', 'pocket-session-preferences.json')
+);
+
+const entryKey = (provider: LLMProvider, sessionId: string): string => `${provider}:${sessionId}`;
+
+export const isPocketSessionEffort = (value: unknown): value is PocketSessionEffort => (
+  typeof value === 'string' && POCKET_SESSION_EFFORTS.includes(value as PocketSessionEffort)
+);
+
+const emptyPreferences = (provider: LLMProvider, sessionId: string): PocketSessionPreferences => ({
+  provider,
+  sessionId,
+  model: null,
+  effort: DEFAULT_EFFORT,
+  updatedAt: null,
+});
+
+const isPreference = (value: unknown): value is PocketSessionPreferences => {
+  if (!value || typeof value !== 'object') return false;
+  const record = value as Record<string, unknown>;
+  return typeof record.provider === 'string'
+    && typeof record.sessionId === 'string'
+    && (typeof record.model === 'string' || record.model === null)
+    && isPocketSessionEffort(record.effort)
+    && (typeof record.updatedAt === 'string' || record.updatedAt === null);
+};
+
+const readPreferencesFile = async (filePath: string): Promise<PocketSessionPreferencesFile> => {
+  try {
+    const parsed = JSON.parse(await readFile(filePath, 'utf8')) as Record<string, unknown>;
+    const rawEntries = parsed.version === 1 && parsed.entries && typeof parsed.entries === 'object'
+      ? parsed.entries as Record<string, unknown>
+      : {};
+    const entries: Record<string, PocketSessionPreferences> = {};
+    for (const [key, value] of Object.entries(rawEntries)) {
+      if (isPreference(value)) entries[key] = value;
+    }
+    return { version: 1, entries };
+  } catch {
+    return { version: 1, entries: {} };
+  }
+};
+
+const writePreferencesFile = async (
+  filePath: string,
+  payload: PocketSessionPreferencesFile,
+): Promise<void> => {
+  await mkdir(path.dirname(filePath), { recursive: true });
+  const temporaryPath = `${filePath}.${process.pid}.${randomUUID()}.tmp`;
+  await writeFile(temporaryPath, `${JSON.stringify(payload, null, 2)}\n`, { encoding: 'utf8', mode: 0o600 });
+  await rename(temporaryPath, filePath);
+};
+
+export async function readPocketSessionPreferences(
+  provider: LLMProvider,
+  sessionId: string,
+  options: { filePath?: string } = {},
+): Promise<PocketSessionPreferences> {
+  const normalizedSessionId = sessionId.trim();
+  if (!normalizedSessionId) return emptyPreferences(provider, normalizedSessionId);
+  const payload = await readPreferencesFile(options.filePath ?? preferencesPath());
+  return payload.entries[entryKey(provider, normalizedSessionId)]
+    ?? emptyPreferences(provider, normalizedSessionId);
+}
+
+export async function writePocketSessionPreferences(
+  provider: LLMProvider,
+  sessionId: string,
+  input: { model?: string | null; effort?: PocketSessionEffort },
+  options: { filePath?: string } = {},
+): Promise<PocketSessionPreferences> {
+  const normalizedSessionId = sessionId.trim();
+  if (!normalizedSessionId) throw new Error('sessionId is required');
+  const filePath = options.filePath ?? preferencesPath();
+  const payload = await readPreferencesFile(filePath);
+  const previous = payload.entries[entryKey(provider, normalizedSessionId)]
+    ?? emptyPreferences(provider, normalizedSessionId);
+  const model = input.model === undefined
+    ? previous.model
+    : (typeof input.model === 'string' ? input.model.trim().slice(0, 200) || null : null);
+  const next: PocketSessionPreferences = {
+    provider,
+    sessionId: normalizedSessionId,
+    model,
+    effort: input.effort ?? previous.effort,
+    updatedAt: new Date().toISOString(),
+  };
+  payload.entries[entryKey(provider, normalizedSessionId)] = next;
+  await writePreferencesFile(filePath, payload);
+  return next;
+}
