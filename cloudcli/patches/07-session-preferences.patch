index 0000000000000000000000000000000000000000..7f8103a836b77d68ca600ff7815f8cb1327a2d7b
--- /dev/null
+++ b/server/modules/providers/tests/pocket-session-preferences.service.test.ts
@@ -0,0 +1,30 @@
+import assert from 'node:assert/strict';
+import { mkdtemp, rm } from 'node:fs/promises';
+import os from 'node:os';
+import path from 'node:path';
+import test from 'node:test';
+
+import {
+  readPocketSessionPreferences,
+  writePocketSessionPreferences,
+} from '@/modules/providers/services/pocket-session-preferences.service.js';
+
+test('Pocket session model and effort preferences persist independently', async (t) => {
+  const directory = await mkdtemp(path.join(os.tmpdir(), 'pocket-session-preferences-'));
+  const filePath = path.join(directory, 'preferences.json');
+  t.after(() => rm(directory, { recursive: true, force: true }));
+
+  assert.deepEqual(await readPocketSessionPreferences('codex', 'session-1', { filePath }), {
+    provider: 'codex', sessionId: 'session-1', model: null, effort: 'high', updatedAt: null,
+  });
+
+  await writePocketSessionPreferences('codex', 'session-1', {
+    model: 'gpt-5.7-sol', effort: 'low',
+  }, { filePath });
+  await writePocketSessionPreferences('codex', 'session-1', { effort: 'xhigh' }, { filePath });
+
+  const restored = await readPocketSessionPreferences('codex', 'session-1', { filePath });
+  assert.equal(restored.model, 'gpt-5.7-sol');
+  assert.equal(restored.effort, 'xhigh');
+  assert.ok(restored.updatedAt);
+});
