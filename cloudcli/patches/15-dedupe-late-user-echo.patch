index 0000000..da38257
--- /dev/null
+++ b/src/stores/useSessionStore.test.ts
@@ -0,0 +1,42 @@
+import assert from 'node:assert/strict';
+import test from 'node:test';
+import { createServer } from 'vite';
+
+import type { NormalizedMessage } from './useSessionStore';
+
+const vite = await createServer({
+  appType: 'custom',
+  optimizeDeps: { noDiscovery: true },
+  server: { middlewareMode: true },
+});
+const { computeMerged } = await vite.ssrLoadModule('/src/stores/useSessionStore.ts');
+
+test.after(async () => {
+  await vite.close();
+});
+
+function userMessage(id: string, timestamp: string, content: string): NormalizedMessage {
+  return {
+    id,
+    sessionId: 'session-1',
+    timestamp,
+    provider: 'codex',
+    kind: 'text',
+    role: 'user',
+    content,
+  };
+}
+
+test('late non-local realtime user echo is omitted after server history refresh', () => {
+  const persisted = userMessage('server-user-1', '2026-07-18T07:30:35.000Z', '对吗');
+  const lateRealtime = userMessage('codex-event-9', '2026-07-18T07:30:53.000Z', '对吗');
+
+  assert.deepEqual(computeMerged([persisted], [lateRealtime]), [persisted]);
+});
+
+test('same prompt outside the send window remains a distinct user turn', () => {
+  const earlier = userMessage('server-user-1', '2026-07-18T07:20:00.000Z', '对吗');
+  const repeatedLater = userMessage('codex-event-10', '2026-07-18T07:30:53.000Z', '对吗');
+
+  assert.deepEqual(computeMerged([earlier], [repeatedLater]), [earlier, repeatedLater]);
+});
