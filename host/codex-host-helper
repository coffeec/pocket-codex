#!/usr/bin/env bash
set -euo pipefail

PAL_SERVICE=palworld
FRP_SERVICE=sakurafrp-palworld
PRIVILEGED=/usr/local/sbin/pocket-host-actions
BACKUP_DIR=/mnt/d/palworld-backups
requested=${SSH_ORIGINAL_COMMAND:-}

service_state() {
  local service=$1
  printf '%s: ' "$service"
  systemctl is-active "$service" 2>/dev/null || true
}

battery_status() {
  local battery
  battery=$(find /sys/class/power_supply -maxdepth 1 -type l -name 'BAT*' | head -n 1)
  [[ -n "$battery" ]] || { echo "battery not found"; return 0; }
  local field
  for field in status capacity energy_now energy_full energy_full_design charge_now charge_full charge_full_design; do
    [[ -r "$battery/$field" ]] && printf '%s: %s\n' "$field" "$(<"$battery/$field")"
  done
}

redact_logs() {
  sed -E \
    -e 's/([A-Za-z0-9_]*(token|password|secret|api[_-]?key)[A-Za-z0-9_]*[[:space:]]*[:=][[:space:]]*)[^[:space:],;]+/\1[REDACTED]/Ig' \
    -e 's/(Authorization:[[:space:]]*(Bearer|Basic)[[:space:]]+)[^[:space:]]+/\1[REDACTED]/Ig' \
    | cut -c1-500
}

case "$requested" in
  status)
    echo "== uptime =="
    uptime
    echo "== services =="
    service_state "$PAL_SERVICE"
    service_state "$FRP_SERVICE"
    echo "== memory =="
    free -h
    echo "== root disk =="
    df -h /
    echo "== temperatures =="
    LC_ALL=C sensors 2>/dev/null || echo "sensors unavailable"
    echo "== battery =="
    battery_status
    ;;
  cpu)
    uptime
    awk -F: '/cpu MHz/ {sum+=$2; n++} END {if(n) printf "average: %.0f MHz across %d threads\n", sum/n, n}' /proc/cpuinfo
    LC_ALL=C sensors 2>/dev/null || echo "sensors unavailable"
    ;;
  memory)
    free -h
    ;;
  top)
    ps -eo pid,comm,%cpu,%mem,rss,etimes --sort=-%cpu | head -n 16
    ;;
  disk)
    df -hT
    ;;
  battery)
    battery_status
    ;;
  pal-status)
    systemctl status "$PAL_SERVICE" --no-pager -l 2>&1 | head -n 60 | redact_logs
    ;;
  pal-logs\ *)
    read -r action lines minutes extra <<<"$requested"
    [[ -z "${extra:-}" && "$lines" =~ ^(20|50|100)$ && "$minutes" =~ ^(15|60|360|1440)$ ]] || exit 126
    journalctl -u "$PAL_SERVICE" --since "$minutes minutes ago" -n "$lines" --no-pager -o short-iso 2>&1 | redact_logs
    ;;
  frp-status)
    systemctl status "$FRP_SERVICE" --no-pager -l 2>&1 | head -n 50 | redact_logs
    ;;
  players)
    exec "$PRIVILEGED" players
    ;;
  broadcast\ *)
    read -r action encoded extra <<<"$requested"
    [[ -z "${extra:-}" && ${#encoded} -le 1068 && "$encoded" =~ ^[A-Za-z0-9+/]+={0,2}$ ]] || exit 126
    exec "$PRIVILEGED" broadcast "$encoded"
    ;;
  backup-usage)
    exec "$PRIVILEGED" backup-usage
    ;;
  docker-cache)
    exec "$PRIVILEGED" docker-cache
    ;;
  pal-backup)
    exec "$PRIVILEGED" pal-backup
    ;;
  restart-palworld)
    exec "$PRIVILEGED" restart-palworld
    ;;
  restart-frp)
    exec "$PRIVILEGED" restart-frp
    ;;
  restart-pocket)
    exec "$PRIVILEGED" restart-pocket
    ;;
  *)
    echo "Denied. Unknown hostctl request." >&2
    exit 126
    ;;
esac
